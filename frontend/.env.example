# OpenWeatherMap API Key (free tier)
# Get yours at: https://openweathermap.org/api
VITE_OWM_KEY=

# Google Places API key (for hyperlocal place detection)
VITE_GOOGLE_PLACES_API_KEY=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI Backend URL (FastAPI with Gemini - Planner, Insights)
# Run: cd AI-Backend && uvicorn app:app --reload
VITE_AI_BACKEND_URL=http://localhost:8000

# LLM provider for frontend AI pipeline (gemini | groq)
VITE_LLM_PROVIDER=gemini

# Gemini (optional)
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-1.5-flash

# Groq (optional)
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.1-8b-instant

# Notification backend (Node/Express)
VITE_NOTIFICATION_BACKEND_URL=http://localhost:5000

# Web Push VAPID public key from Notification-Backend
VITE_NOTIFICATION_VAPID_PUBLIC_KEY=
