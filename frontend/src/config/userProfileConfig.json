          "options": ["bike", "cycle", "van"],
          "label": "Delivery vehicle",
          "required": true
        },
        {
          "key": "delivery_hours",
          "type": "select",
          "options": ["morning", "afternoon", "evening", "full_day"],
          "label": "Working hours",
          "required": true
        },
        {
          "key": "daily_distance",
          "type": "range",
          "min": 1,
          "max": 200,
          "step": 5,
          "label": "Daily delivery distance (km)",
          "required": true
        },
        {
          "key": "delivery_deadline_strictness",
          "type": "select",
          "options": ["low", "medium", "high", "very_high"],
          "label": "How strict are delivery time windows?",
          "required": true
        }
      ],
      "optional": [
        {
          "key": "rain_impact",
          "type": "boolean",
          "label": "Rain affects delivery?",
          "required": false
        },
        {
          "key": "fragile_shipments",
          "type": "boolean",
          "label": "Do you often carry fragile items?",
          "required": false
        },
        {
          "key": "special_requirements",
          "type": "text",
          "label": "Specific delivery/weather needs (optional)",
          "placeholder": "Example: prioritize routes with less waterlogging",
          "required": false
        }
      ]
    },
    "senior_citizen": {
      "compulsory": [
        {
          "key": "health_sensitivity",
          "type": "select",
          "options": ["low", "medium", "high"],
          "label": "Health sensitivity",
          "required": true
        },
        {
          "key": "outdoor_frequency",
          "type": "select",
          "options": ["rarely", "few_times_week", "daily"],
          "label": "How often do you go outdoors?",
          "required": true
        }
      ],
      "optional": [
        {
          "key": "aqi_sensitive",
          "type": "boolean",
          "label": "Sensitive to air quality?",
          "required": false
        },
        {
          "key": "heat_sensitive",
          "type": "boolean",
          "label": "Sensitive to heat?",
          "required": false
        },
        {
          "key": "cold_sensitive",
          "type": "boolean",
          "label": "Sensitive to cold?",
          "required": false
        },
        {
          "key": "special_requirements",
          "type": "text",
          "label": "Specific health/weather needs (optional)",
          "placeholder": "Example: avoid outdoor alerts when AQI is above moderate",
          "required": false
        }
      ]
    },
    "student": {
      "compulsory": [
        {
          "key": "travel_mode",
          "type": "select",
          "options": ["walking", "bike", "bus", "car"],
