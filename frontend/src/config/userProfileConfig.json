{
  "version": "2.1",
  "user_types": {
    "general": {
      "compulsory": [
        {
          "key": "outdoor_activity",
          "type": "select",
          "label": "Outdoor activity level",
          "options": ["low", "medium", "high"],
          "required": true
        },
        {
          "key": "typical_outdoor_time",
          "type": "select",
          "label": "When are you usually outside?",
          "options": ["early_morning", "morning", "afternoon", "evening", "night", "varies"],
          "required": true
        }
      ],
      "optional": [
        {
          "key": "heat_sensitive",
          "type": "boolean",
          "label": "Sensitive to heat?",
          "required": false
        },
        {
          "key": "aqi_sensitive",
          "type": "boolean",
          "label": "Sensitive to air quality?",
          "required": false
        },
        {
          "key": "rain_tolerance",
          "type": "range",
          "min": 0,
          "max": 10,
          "step": 1,
          "label": "Rain tolerance (0 low, 10 high)",
          "required": false
        },
        {
          "key": "special_requirements",
          "type": "text",
          "label": "Specific weather needs (optional)",
          "placeholder": "Example: avoid noon heat, prefer low AQI routes",
          "required": false
        }
      ]
    },
    "driver": {
      "compulsory": [
        {
          "key": "driving_distance_km",
          "type": "range",
          "min": 1,
          "max": 500,
          "step": 5,
          "label": "Daily travel distance (km)",
          "required": true
        },
        {
          "key": "vehicle_type",
          "type": "select",
          "options": ["bike", "car", "truck", "bus"],
          "label": "Vehicle type",
          "required": true
        },
        {
          "key": "travel_time",
          "type": "select",
          "options": ["morning", "afternoon", "evening", "night", "full_day"],
          "label": "Driving time",
          "required": true
        },
        {
          "key": "route_type",
          "type": "select",
          "options": ["city", "highway", "mixed", "hilly"],
          "label": "Primary route type",
          "required": true
        }
      ],
      "optional": [
        {
          "key": "long_route",
          "type": "boolean",
          "label": "Long highway routes?",
          "required": false
        },
        {
          "key": "night_driving_frequency",
          "type": "select",
          "options": ["never", "rarely", "sometimes", "often", "daily"],
          "label": "Night driving frequency",
          "required": false
        },
        {
          "key": "visibility_priority",
          "type": "range",
          "min": 1,
          "max": 10,
          "step": 1,
          "label": "How important is visibility forecasting?",
          "required": false
        },
        {
          "key": "special_requirements",
          "type": "text",
          "label": "Specific driving/weather needs (optional)",
          "placeholder": "Example: avoid fog-prone stretches and heavy rain windows",
          "required": false
        }
      ]
    },
    "worker": {
      "compulsory": [
        {
          "key": "work_type",
          "type": "select",
          "options": ["construction", "field", "manual_labor"],
          "label": "Type of work",
          "required": true
        },
        {
          "key": "work_hours",
          "type": "select",
          "options": ["morning", "afternoon", "full_day"],
          "label": "Working hours",
          "required": true
        },
        {
          "key": "outdoor_exposure",
          "type": "range",
          "min": 0,
          "max": 100,
          "step": 10,
          "label": "Outdoor exposure (%)",
          "required": true
        },
        {
          "key": "physical_intensity",
          "type": "select",
          "options": ["low", "moderate", "high", "very_high"],
          "label": "Work intensity",
          "required": true
        }
      ],
      "optional": [
        {
          "key": "has_shelter",
          "type": "boolean",
          "label": "Access to shelter?",
          "required": false
        },
        {
          "key": "protective_gear",
          "type": "boolean",
          "label": "Do you usually use protective gear?",
          "required": false
        },
        {
          "key": "break_flexibility",
          "type": "select",
          "options": ["low", "medium", "high"],
          "label": "Can work breaks be shifted due to weather?",
          "required": false
        },
        {
          "key": "special_requirements",
          "type": "text",
          "label": "Specific work/weather needs (optional)",
          "placeholder": "Example: avoid peak heat windows for heavy tasks",
          "required": false
        }
      ]
    },
    "office_employee": {
      "compulsory": [
        {
          "key": "commute_distance_km",
          "type": "range",
          "min": 1,
          "max": 100,
          "step": 1,
          "label": "Distance to office (km)",
          "required": true
        },
        {
          "key": "transport_mode",
          "type": "select",
          "options": ["walking", "bike", "car", "bus", "train"],
          "label": "Transport mode",
          "required": true
        },
        {
          "key": "office_timing",
          "type": "select",
          "options": ["morning", "day", "evening"],
          "label": "Office timing",
          "required": true
        },
        {
          "key": "commute_flexibility",
          "type": "select",
          "options": ["fixed", "slightly_flexible", "flexible", "work_from_home_possible"],
          "label": "Commute flexibility",
          "required": true
        }
      ],
      "optional": [
        {
          "key": "traffic_sensitive",
          "type": "boolean",
          "label": "Want traffic/weather alerts?",
          "required": false
        },
        {
          "key": "last_mile_walk_minutes",
          "type": "number",
          "min": 0,
          "max": 120,
          "step": 5,
          "unit": "min",
          "label": "Last-mile walking time",
          "required": false
        },
        {
          "key": "special_requirements",
          "type": "text",
          "label": "Specific commute/weather needs (optional)",
          "placeholder": "Example: keep me away from heavy-rain commute windows",
          "required": false
        }
      ]
    },
    "farmer": {
      "compulsory": [
        {
          "key": "crop_type",
          "type": "select",
          "options": ["wheat", "rice", "soybean", "cotton", "vegetables", "other"],
          "label": "Crop type",
          "required": true
        },
        {
          "key": "farming_stage",
          "type": "select",
          "options": ["sowing", "growing", "harvesting", "spraying"],
          "label": "Current activity",
          "required": true
        },
        {
          "key": "irrigation",
          "type": "select",
          "options": ["rainfed", "manual", "drip", "sprinkler"],
          "label": "Irrigation type",
          "required": true
        },
        {
          "key": "soil_drainage",
          "type": "select",
          "options": ["poor", "moderate", "good"],
          "label": "Soil drainage",
          "required": true
        }
      ],
      "optional": [
        {
          "key": "farm_size",
          "type": "range",
          "min": 1,
          "max": 100,
          "step": 1,
          "label": "Farm size (acres)",
          "required": false
        },
        {
          "key": "crop_type_other",
          "type": "text",
          "label": "Specify crop type",
          "required": true,
          "depends_on": {
            "key": "crop_type",
            "value": "other"
          }
        },
        {
          "key": "sensitive_to_unseasonal_rain",
          "type": "boolean",
          "label": "Is unseasonal rain a major risk?",
          "required": false
        },
        {
          "key": "special_requirements",
          "type": "text",
          "label": "Specific crop/weather needs (optional)",
          "placeholder": "Example: alert before spraying when wind is high",
          "required": false
        }
      ]
    },
    "delivery": {
      "compulsory": [
        {
          "key": "delivery_mode",
