      "compulsory": [
        {
          "key": "business_type",
          "type": "select",
          "options": ["retail", "food", "outdoor_shop", "warehouse"],
          "label": "Business type",
          "required": true
        },
        {
          "key": "operating_hours",
          "type": "select",
          "options": ["morning", "day", "evening", "full_day"],
          "label": "Operating hours",
          "required": true
        },
        {
          "key": "footfall_dependence",
          "type": "select",
          "options": ["low", "medium", "high"],
          "label": "How weather-sensitive is customer footfall?",
          "required": true
        }
      ],
      "optional": [
        {
          "key": "weather_impact",
          "type": "boolean",
          "label": "Weather affects business?",
          "required": false
        },
        {
          "key": "inventory_weather_sensitive",
          "type": "boolean",
          "label": "Is inventory weather-sensitive?",
          "required": false
